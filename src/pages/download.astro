---
import Navbar from "@/components/sections/Navbar.astro";
import Layout from "@/layouts/Layout.astro";
import { getVersions } from "@/lib/versions";

var versions = await getVersions();
var latestVersion = versions[0];
var olderVersions = versions.slice(1);
---

<Layout title={"SteelMC - " + Astro.locals.t("download")}>
  <Navbar />
  
  <main class="w-full px-4 mt-28 mb-16 relative z-10 flex flex-col items-center">
    
    <!-- Latest Version Section -->
    {latestVersion && (
      <div class="w-full max-w-2xl text-center mb-8">
        <h1 class="text-sm font-minecraft font-bold tracking-widest text-teal-600 dark:text-emerald-400 uppercase mb-4">
          {Astro.locals.t("latestVersion")}
        </h1>
        
        <!-- Latest Version Card -->
        <div class="w-full p-8 rounded-3xl backdrop-blur-md bg-white/80 dark:bg-teal-950/70 border border-teal-200/60 dark:border-white/10 shadow-2xl flex flex-col items-center gap-6">
          <div class="text-center">
            <h2 class="text-4xl md:text-5xl font-minecraft font-bold text-teal-950 dark:text-white">
              Version {latestVersion.steel_version}
            </h2>
            <p class="text-lg md:text-xl text-teal-700 dark:text-teal-300 mt-2">
              For Minecraft {latestVersion.mc_version}
            </p>
          </div>
          
          <!-- Platform download buttons -->
          <div class="flex flex-col sm:flex-row gap-3 w-full max-w-md justify-center mt-2">
            {latestVersion.builds.map((build) => {
              var platform = String(build.platform).charAt(0).toUpperCase() + String(build.platform).slice(1);
              return (
                <a
                  href={build.download}
                  download={build.name}
                  class="flex-1 px-6 py-3 font-minecraft font-bold rounded-[50px] text-sm bg-teal-600 text-white dark:bg-white dark:text-teal-950 hover:bg-teal-700 dark:hover:bg-gray-100 hover:-translate-y-px transition-all duration-200 ease-out text-center shadow-lg hover:shadow-xl"
                >
                  {platform}
                </a>
              );
            })}
          </div>
          
          <!-- Release badge -->
          <div class="flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 text-xs font-semibold mt-2">
            <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            {Astro.locals.t("latestRelease")}
          </div>
        </div>
      </div>
    )}

    <!-- Toggle Section -->
    {olderVersions.length > 0 && (
      <div id="toggle-section" class="w-full max-w-2xl text-center mt-6 flex flex-col items-center gap-4 transition-all duration-300">
        <p class="text-teal-700 dark:text-gray-300 font-minecraft text-sm">
          {Astro.locals.t("needOlderVersion")}
        </p>
        <button
          id="btn-view-previous"
          class="px-8 py-3 font-minecraft font-bold rounded-[50px] text-sm bg-black/5 border border-black/10 text-black/80 dark:bg-white/5 dark:border-white/10 dark:text-white/85 cursor-pointer hover:bg-black/10 dark:hover:bg-white/10 hover:-translate-y-px transition-all duration-200 ease-out shadow-sm"
        >
          {Astro.locals.t("viewPreviousVersions")}
        </button>
      </div>
    )}

    <!-- Older Versions Section (Hidden on load) -->
    {olderVersions.length > 0 && (
      <div id="older-versions-section" class="w-full max-w-2xl mt-12" style="display:none">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="text-xl font-minecraft font-bold text-teal-950 dark:text-white shrink-0">
            {Astro.locals.t("olderVersions")}
          </h2>
          <div class="flex-1 h-px bg-teal-200/60 dark:bg-white/10"></div>
        </div>

        <ul class="flex flex-col gap-4">
          {olderVersions.map((version) => (
            <li class="p-5 rounded-2xl backdrop-blur-md bg-white/60 dark:bg-teal-950/40 border border-teal-200/40 dark:border-white/5 shadow-md flex items-center justify-between gap-4">
              <div class="flex flex-col justify-center">
                <h3 class="text-xl font-bold text-teal-950 dark:text-white">
                  Version {version.steel_version}
                </h3>
                <p class="text-sm text-teal-600 dark:text-gray-400 mt-0.5">
                  For Minecraft {version.mc_version}
                </p>
              </div>
              <div class="flex gap-2">
                {version.builds.map((build) => {
                  var platform = String(build.platform).charAt(0).toUpperCase() + String(build.platform).slice(1);
                  return (
                    <a
                      href={build.download}
                      download={build.name}
                      class="px-4 py-1.5 font-minecraft font-bold rounded-[50px] text-xs bg-black/5 border border-black/10 text-black/80 dark:bg-white/5 dark:border-white/10 dark:text-white/85 cursor-pointer hover:bg-black/10 dark:hover:bg-white/10 hover:-translate-y-px transition-all duration-200 ease-out text-center"
                    >
                      {platform}
                    </a>
                  );
                })}
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}
    
  </main>
</Layout>

<script>
  const btnViewPrevious = document.getElementById("btn-view-previous");
  const toggleSection = document.getElementById("toggle-section");
  const olderVersionsSection = document.getElementById("older-versions-section") as HTMLElement | null;

  btnViewPrevious?.addEventListener("click", () => {
    // Fade out the toggle prompt
    if (toggleSection) {
      toggleSection.classList.add("hidden");
    }

    // Reveal older versions with the global fade-in-up animation
    if (olderVersionsSection) {
      olderVersionsSection.style.display = "block";
      olderVersionsSection.classList.add("animate-fade-in-up");
    }
  });
</script>
