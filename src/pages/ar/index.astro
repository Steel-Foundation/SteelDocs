---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/sections/Navbar.astro";
import Hero from "@/components/sections/Hero.astro";
import ChooseDocs from "@/components/sections/ChooseDocs.astro";
import Community from "@/components/sections/Community.astro";
import FooterStatus from "@/components/sections/FooterStatus.astro";
---

<Layout title="SteelMC">
  <Navbar />
  <Hero
    pillText="قيد التطوير"
    heroTitle="Steel"
    heroTitleHighlight="MC"
    subtitle="ماينكرافت مطورة بالطريقة الصحيحة. مبنية بلغة Rust، ومصممة لدعم تعدد الخيوط البرمجية. نهدف إلى مطابقة اللعبة الأساسية (vanilla)، والأداء العالي، والتخصيص."
    mainCtaText="انضم إلينا!"
    secondCtaText="المستندات"
  />
  <main
    class="container mx-4 w-auto lg:mx-auto max-w-280 px-4 mt-16 lg:-mt-12 text-white relative z-10"
  >
    <ChooseDocs
      sectionLabel="اختر مستنداتك!"
      sectionTitle="ماذا تريد أن تفعل؟"
      sectionDescription="تم تصميم Steel بعناية للجميع. مطورين أم مدراء؟ لا يهم ما تريد القيام به، هناك مستندات مناسبة لك!"
      adminHref="./getting-started/installation/"
      adminImage="/admin.png"
      adminImageAlt="مستندات المدير"
      adminLabel="المدير"
      devHref="./development/start-contributing/"
      devImage="/contributor.png"
      devImageAlt="مستندات المطور"
      devLabel="المطور"
    />
    <Community
      heading="مهتم بالمشروع؟"
      headingHighlight="انضم إلينا!"
      descriptionBold1="Steel هو مكان يجتمع فيه الناس"
      descriptionMiddle=" للبرمجة والمحادثة والاستمتاع بالوقت. من المطورين الموهوبين إلى الثرثارين، "
      descriptionBold2="الجميع مرحب به!"
      descriptionAfter=" نحن مجرد مجموعة من الأشخاص نحاول إنشاء خادم ماينكرافت رائع."
    />
    <FooterStatus
      prefix="Steel"
      rotatingTexts={[
        "قيد التطوير",
        "غير جاهز بعد",
        "سريع جداً",
        "مبني بلغة Rust",
        "يطبخ!",
        "يشكر المساهمين",
      ]}
    />
  </main>
</Layout>
